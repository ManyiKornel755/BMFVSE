{
	"info": {
		"name": "BMFVSE - Trainings Tests",
		"description": "Edzés kezelesi tesztek a BMFVSE backend API-hoz",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Get All Trainings",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Statusz kod 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response tomb\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an('array');",
							"});",
							"",
							"pm.test(\"Training objektumok helyes struktura\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.length > 0) {",
							"        pm.expect(jsonData[0]).to.have.property('id');",
							"        pm.expect(jsonData[0]).to.have.property('title');",
							"        pm.expect(jsonData[0]).to.have.property('event_date');",
							"        pm.expect(jsonData[0].event_type).to.equal('training');",
							"    }",
							"});",
							"",
							"pm.test(\"Response ideje kevesebb mint 1500ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(1500);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/trainings",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"trainings"
					]
				},
				"description": "Osszes jovoben esedékes edzés lekerese"
			},
			"response": []
		},
