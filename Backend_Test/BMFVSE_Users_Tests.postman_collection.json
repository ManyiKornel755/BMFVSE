{
	"info": {
		"name": "BMFVSE - Users Tests",
		"description": "Felhasznalo kezelesi tesztek a BMFVSE backend API-hoz",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Get All Users - Admin",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Statusz kod 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response tomb\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an('array');",
							"});",
							"",
							"pm.test(\"Users tartalmaznak kotelező mezőket\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.length > 0) {",
							"        pm.expect(jsonData[0]).to.have.property('id');",
							"        pm.expect(jsonData[0]).to.have.property('email');",
							"        pm.expect(jsonData[0]).to.not.have.property('password');",
							"    }",
							"});",
							"",
							"pm.test(\"Response ideje kevesebb mint 1000ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(1000);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/users",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users"
					]
				},
				"description": "Osszes felhasznalo lekerese (admin jogosultsag szukseges)"
			},
			"response": []
		},
		{
			"name": "Get My Profile",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Statusz kod 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"User objektum helyes struktura\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an('object');",
							"    pm.expect(jsonData).to.have.property('id');",
							"    pm.expect(jsonData).to.have.property('email');",
							"    pm.expect(jsonData).to.not.have.property('password');",
							"});",
							"",
							"pm.test(\"Roles property letezik\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('roles');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/users/me",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users",
						"me"
					]
				},
				"description": "Sajat profil lekerese"
			},
			"response": []
		},
		{
			"name": "Update My Profile",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Statusz kod 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Modositott adatok visszajonnek\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('phone');",
							"});",
							"",
							"pm.test(\"Jelszo nincs a response-ban\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.not.have.property('password');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"phone\": \"+36301234567\",\n    \"address\": \"Budapest, Test utca 1.\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/users/me",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users",
						"me"
					]
				},
				"description": "Sajat profil frissitese"
			},
			"response": []
